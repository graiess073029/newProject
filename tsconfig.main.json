{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",          // main + preload doivent être en CJS
    "outDir": "dist",
    "rootDir": ".",                // racine du projet
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "noEmitOnError": true,
    "lib": ["ES2020"],
    "sourceMap" : true
  },
  "include": [
    "index.ts",        // ton main
    "services/**/*",   // logique côté Node
    "preload/**/*"     // scripts preload
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
