{
  "name": "desktop",
  "version": "1.0.0",
  "description": "My Desktop",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json && copy C:\\Users\\graie\\Documents\\customDesktop\\le5er\\renderer\\index.html C:\\Users\\graie\\Documents\\customDesktop\\le5er\\dist\\renderer && copy C:\\Users\\graie\\Documents\\customDesktop\\le5er\\renderer\\styles.css C:\\Users\\graie\\Documents\\customDesktop\\le5er\\dist\\renderer",
    "watch": "tsc --watch",
    "start": "electron .",
    "dev": "npm run build && electron ."
  },
  "author": "Youssef Graiess",
  "license": "",
  "dependencies": {
    "csv-parser": "^3.2.0",
    "datatables.net-dt": "^2.3.5",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "hwinfo-reader": "^1.0.1",
    "pidusage": "^4.0.1",
    "ps-list": "^9.0.0",
    "systeminformation": "^5.27.11",
    "tail": "^2.2.6"
  },
  "devDependencies": {
    "@types/electron": "^1.6.12",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/webpack-env": "^1.18.8",
    "electron": "^39.2.4",
    "electron-packager": "^17.1.2",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.example.myelectronapp",
    "productName": "Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "portable",
      "win": {
        "icon": "assets/icon.ico"
      }
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
